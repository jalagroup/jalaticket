{
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "deno.enablePaths": [
    "supabase/functions"
  ],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "flutterTools.displayGetxContextMenu": true,
  "flutterTools.displayMobxContextMenu": false,
  "flutterTools.displayModularContextMenu": false,
  "flutterTools.displayRiverpodContextMenu": false,
  "jdk.java.imports.groups": [
    "java",
    "javax",
    "org",
    "com",
    ""
  ]
}
